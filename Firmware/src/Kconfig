menu "Product Topology"

# ---- Oxygen Cells ----

config CELL_COUNT
	int "Number of oxygen cells"
	default 3
	range 1 3
	help
	  Number of oxygen sensor slots populated on this unit.

choice CELL_1_TYPE
	prompt "Cell 1 type"
	default CELL_1_TYPE_ANALOG

config CELL_1_TYPE_ANALOG
	bool "Analog galvanic"

config CELL_1_TYPE_DIVEO2
	bool "DiveO2 digital"

config CELL_1_TYPE_O2S
	bool "Oxygen Scientific digital"

endchoice

choice CELL_2_TYPE
	prompt "Cell 2 type"
	default CELL_2_TYPE_ANALOG
	depends on CELL_COUNT >= 2

config CELL_2_TYPE_ANALOG
	bool "Analog galvanic"

config CELL_2_TYPE_DIVEO2
	bool "DiveO2 digital"

config CELL_2_TYPE_O2S
	bool "Oxygen Scientific digital"

endchoice

choice CELL_3_TYPE
	prompt "Cell 3 type"
	default CELL_3_TYPE_ANALOG
	depends on CELL_COUNT >= 3

config CELL_3_TYPE_ANALOG
	bool "Analog galvanic"

config CELL_3_TYPE_DIVEO2
	bool "DiveO2 digital"

config CELL_3_TYPE_O2S
	bool "Oxygen Scientific digital"

endchoice

# ---- Derived cell capabilities ----

config HAS_DIGITAL_CELL
	bool
	default y if CELL_1_TYPE_DIVEO2 || CELL_1_TYPE_O2S || \
	             CELL_2_TYPE_DIVEO2 || CELL_2_TYPE_O2S || \
	             CELL_3_TYPE_DIVEO2 || CELL_3_TYPE_O2S

# ---- Power Architecture ----

choice POWER_MODE
	prompt "Power source mode"
	default POWER_MODE_BATTERY

config POWER_MODE_BATTERY
	bool "Battery only"

config POWER_MODE_BATTERY_THEN_CAN
	bool "Battery with CAN fallback"

config POWER_MODE_CAN
	bool "CAN bus power only"

endchoice

choice BATTERY_CHEMISTRY
	prompt "Battery chemistry / voltage threshold"
	default BATTERY_CHEMISTRY_LI2S
	depends on !POWER_MODE_CAN

config BATTERY_CHEMISTRY_9V
	bool "9V alkaline"

config BATTERY_CHEMISTRY_LI1S
	bool "1S lithium (3.7V)"

config BATTERY_CHEMISTRY_LI2S
	bool "2S lithium (7.4V)"

config BATTERY_CHEMISTRY_LI3S
	bool "3S lithium (11.1V)"

endchoice

endmenu # Product Topology

# ---- Solenoid Role Mapping ----

menu "Solenoid Role Mapping"
	depends on SOLENOID

config SOL_O2_INJECT_CHANNEL
	int "O2 injection solenoid channel"
	default 0
	range 0 3
	help
	  Primary oxygen solenoid, driven by the PID control loop.

config SOL_O2_FLUSH_CHANNEL
	int "O2 calibration flush solenoid channel (-1 = not present)"
	default -1
	range -1 3
	help
	  Oxygen flush solenoid for automated calibration.
	  Set to -1 if this system has no dedicated O2 flush solenoid.

config SOL_DIL_FLUSH_CHANNEL
	int "Diluent calibration flush solenoid channel (-1 = not present)"
	default -1
	range -1 3
	help
	  Diluent flush solenoid for automated calibration.
	  Set to -1 if this system has no dedicated diluent flush solenoid.

config SOL_O2_INJECT_2_CHANNEL
	int "Secondary O2 injection solenoid channel (-1 = not present)"
	default -1
	range -1 3
	help
	  Second oxygen injection solenoid for dual-inject systems.
	  Set to -1 for single-solenoid systems.

config HAS_O2_SOLENOID
	bool
	default y if SOL_O2_INJECT_CHANNEL >= 0

config HAS_FLUSH_SOLENOID
	bool
	default y if SOL_O2_FLUSH_CHANNEL >= 0

endmenu # Solenoid Role Mapping

# ---- Runtime Setting Constraints ----
# These define which runtime options are compiled in and
# what their defaults are. The actual values live in NVS
# and are changeable via UDS.

menu "Runtime Setting Defaults"

choice PPO2_CONTROL_DEFAULT
	prompt "Default PPO2 control mode"
	default PPO2_CONTROL_DEFAULT_OFF if !HAS_O2_SOLENOID
	default PPO2_CONTROL_DEFAULT_MK15

config PPO2_CONTROL_DEFAULT_OFF
	bool "Off (no solenoid control)"

config PPO2_CONTROL_DEFAULT_PID
	bool "PID control"
	depends on HAS_O2_SOLENOID

config PPO2_CONTROL_DEFAULT_MK15
	bool "MK15 OEM style (1.5s on / 6s off)"
	depends on HAS_O2_SOLENOID

endchoice

choice CAL_MODE_DEFAULT
	prompt "Default calibration method"
	default CAL_MODE_DEFAULT_FLUSH if HAS_FLUSH_SOLENOID
	default CAL_MODE_DEFAULT_ABSOLUTE

config CAL_MODE_DEFAULT_DIGITAL_REF
	bool "Digital reference (cal analog against digital)"
	depends on HAS_DIGITAL_CELL

config CAL_MODE_DEFAULT_ABSOLUTE
	bool "Absolute air calibration"

config CAL_MODE_DEFAULT_TOTAL_ABSOLUTE
	bool "Total absolute (rich gas)"

config CAL_MODE_DEFAULT_FLUSH
	bool "Solenoid flush calibration"
	depends on HAS_FLUSH_SOLENOID

endchoice

config DEPTH_COMPENSATION_DEFAULT
	bool "Enable PPO2 depth compensation by default"
	default n
	depends on HAS_O2_SOLENOID
	help
	  Adjusts PID duty cycle based on ambient pressure.
	  Only meaningful when a control solenoid is present.

config EXTENDED_MESSAGES_DEFAULT
	bool "Enable extended DiveCAN messages by default"
	default n

endmenu # Runtime Setting Defaults
