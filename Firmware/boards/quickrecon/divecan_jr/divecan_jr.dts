/dts-v1/;
#include <st/l4/stm32l431Xc.dtsi>
#include <st/l4/stm32l431r(b-c)tx-pinctrl.dtsi>

/ {
	model = "QuickRecon DiveCAN Jr";
	compatible = "quickrecon,divecan-jr";

	chosen {
		zephyr,sram = &sram0;
		zephyr,flash = &flash0;
		zephyr,code-partition = &slot0_partition;
		zephyr,canbus = &can1;
	};

	aliases {
		led0 = &led_0;
		led1 = &led_5;
		watchdog0 = &iwdg;
	};

	leds {
		compatible = "gpio-leds";
		led_0: led_0 {
			gpios = <&gpiob 0 GPIO_ACTIVE_HIGH>;
		};
		led_5: led_5 {
			gpios = <&gpiob 12 GPIO_ACTIVE_HIGH>;
		};
	};

	gpio_keys {
		compatible = "gpio-keys";

		can_silent: can_silent {
			gpios = <&gpioc 15 GPIO_ACTIVE_HIGH>;
		};
	};

	/* Hardware version detection — halts with blink code on mismatch.
	 * JR2: all three pins wired to ground → expected [0, 0, 0] */
	hw_version: hw-version {
		compatible = "quickrecon,hw-version";
		detect-gpios = <&gpioc 0 GPIO_ACTIVE_HIGH>,
			       <&gpioc 9 GPIO_ACTIVE_HIGH>,
			       <&gpioc 10 GPIO_ACTIVE_HIGH>;
		expected-pattern = <0 0 0>;
		error-led-gpios = <&gpiob 0 GPIO_ACTIVE_HIGH>;
	};

	solenoids: solenoids {
		compatible = "quickrecon,solenoid-driver";
		gpios = <&gpiob 4 GPIO_ACTIVE_HIGH>,
			<&gpioc 11 GPIO_ACTIVE_HIGH>,
			<&gpiob 5 GPIO_ACTIVE_HIGH>,
			<&gpioa 7 GPIO_ACTIVE_HIGH>;
		counter = <&sol_timer>;
		max-on-time-us = <100000>;
	};

	/* ---- Power subsystem ----
	 * Jr: single battery source, VBUS on/off only.
	 * battery_en (PA1) controls the VBUS regulator.
	 * Battery voltage sensed on ADC1 channel 4 (PC3) through 7.25x divider.
	 * VCC monitored via internal VBAT sensor (shared regulator with VBUS).
	 */
	vbus_reg: vbus-regulator {
		compatible = "regulator-fixed";
		regulator-name = "vbus";
		enable-gpios = <&gpioa 1 GPIO_ACTIVE_HIGH>;
		regulator-boot-on;
		startup-delay-us = <5000>;
	};

	power: power-subsystem {
		compatible = "quickrecon,power-subsystem";
		vbus-supply = <&vbus_reg>;
		battery-sense-io-channels = <&adc1 4>;
		battery-divider-ratio = <7250>;
		can-enable-gpios = <&gpioc 13 GPIO_ACTIVE_LOW>;
		can-shutdown-gpios = <&gpioc 14 GPIO_ACTIVE_HIGH>;
	};
};

/* ---- Clock tree ----
 * Matches Rev2 for low power: HSE=8MHz, PLL N=12 R=8 → 12MHz SYSCLK
 * PLL Q=4 → 24MHz for CLK48 (RNG clock source)
 */
&clk_hse {
	clock-frequency = <DT_FREQ_M(8)>;
	status = "okay";
};


&pll {
	div-m = <1>;
	mul-n = <12>;
	div-q = <4>;
	div-r = <8>;
	clocks = <&clk_hse>;
	status = "okay";
};

&rcc {
	clocks = <&pll>;
	clock-frequency = <DT_FREQ_M(12)>;
	ahb-prescaler = <1>;
	apb1-prescaler = <1>;
	apb2-prescaler = <1>;
};

/* ---- CAN bus — DiveCAN @ 250kbps ----
 * Rev2 .ioc: Prescaler=6, BS1=13TQ, BS2=2TQ, SJW=4TQ
 * At 12MHz → 125kbps. Firmware overrides to 250kbps at runtime.
 * Jr at 80MHz: prescaler & segments set via Zephyr bus-speed.
 */
&can1 {
	pinctrl-0 = <&can1_rx_pb8 &can1_tx_pb9>;
	pinctrl-names = "default";
	bitrate = <250000>;
	sample-point = <875>;
	status = "okay";
};

/* ---- I2C1 — ADS1115 external ADCs ----
 * Two devices: 0x48 (cells 1+2), 0x49 (cell 3 + aux)
 * PA9 = SCL, PA10 = SDA
 */
&i2c1 {
	pinctrl-0 = <&i2c1_scl_pa9 &i2c1_sda_pa10>;
	pinctrl-names = "default";
	clock-frequency = <I2C_BITRATE_STANDARD>;
	status = "okay";

	adc_ext1: ads1115@48 {
		compatible = "ti,ads1115";
		reg = <0x48>;
		#io-channel-cells = <1>;
	};

	adc_ext2: ads1115@49 {
		compatible = "ti,ads1115";
		reg = <0x49>;
		#io-channel-cells = <1>;
	};
};

/* ---- UARTs — Oxygen sensor cells ----
 * All 19200 baud, 8N1.
 * DMA channels assigned from RM0394 Table 41 (STM32L431 DMA request mapping):
 *   USART1: DMA1 Ch5 (RX, req 2), DMA1 Ch4 (TX, req 2)
 *   USART2: DMA1 Ch6 (RX, req 2), DMA1 Ch7 (TX, req 2)
 *   USART3: DMA1 Ch3 (RX, req 2), DMA1 Ch2 (TX, req 2)
 *
 * USART2 and USART3 have TX/RX swap enabled in Rev2 .ioc
 * (ADVFEATURE_SWAP_ENABLE). For Jr, check if swap is still
 * needed — if so, use the swapped pinctrl variants.
 */

/* Cell 1: PB6 (TX), PB7 (RX) — no swap */
&usart1 {
	pinctrl-0 = <&usart1_tx_pb6 &usart1_rx_pb7>;
	pinctrl-names = "default";
	current-speed = <19200>;
	dmas = <&dma1 5 2 (STM32_DMA_PERIPH_TO_MEMORY | STM32_DMA_MEM_INC |
			    STM32_DMA_PERIPH_8BITS | STM32_DMA_MEM_8BITS)>,
	       <&dma1 4 2 (STM32_DMA_MEMORY_TO_PERIPH | STM32_DMA_MEM_INC |
			    STM32_DMA_PERIPH_8BITS | STM32_DMA_MEM_8BITS)>;
	dma-names = "rx", "tx";
	status = "okay";
};

/* Cell 2: PA2 (TX), PA3 (RX) — Rev2 has swap enabled */
&usart2 {
	pinctrl-0 = <&usart2_tx_pa2 &usart2_rx_pa3>;
	pinctrl-names = "default";
	current-speed = <19200>;
	dmas = <&dma1 6 2 (STM32_DMA_PERIPH_TO_MEMORY | STM32_DMA_MEM_INC |
			    STM32_DMA_PERIPH_8BITS | STM32_DMA_MEM_8BITS)>,
	       <&dma1 7 2 (STM32_DMA_MEMORY_TO_PERIPH | STM32_DMA_MEM_INC |
			    STM32_DMA_PERIPH_8BITS | STM32_DMA_MEM_8BITS)>;
	dma-names = "rx", "tx";
	status = "okay";
};

/* Cell 3: PC4 (TX), PC5 (RX) — Rev2 has swap enabled */
&usart3 {
	pinctrl-0 = <&usart3_tx_pc4 &usart3_rx_pc5>;
	pinctrl-names = "default";
	current-speed = <19200>;
	dmas = <&dma1 3 2 (STM32_DMA_PERIPH_TO_MEMORY | STM32_DMA_MEM_INC |
			    STM32_DMA_PERIPH_8BITS | STM32_DMA_MEM_8BITS)>,
	       <&dma1 2 2 (STM32_DMA_MEMORY_TO_PERIPH | STM32_DMA_MEM_INC |
			    STM32_DMA_PERIPH_8BITS | STM32_DMA_MEM_8BITS)>;
	dma-names = "rx", "tx";
	status = "okay";
};

/* ---- SPI2 — Winbond W25Q512JV external flash ----
 * PB13 = SCK, PB14 = MISO, PB15 = MOSI, PB11 = CS
 */
&spi2 {
	pinctrl-0 = <&spi2_sck_pb13 &spi2_miso_pb14 &spi2_mosi_pb15>;
	pinctrl-names = "default";
	cs-gpios = <&gpiob 11 GPIO_ACTIVE_LOW>;
	status = "okay";

	spi_flash: w25q512@0 {
		compatible = "jedec,spi-nor";
		reg = <0>;
		spi-max-frequency = <6000000>;
		jedec-id = [ef 40 20];
		size = <DT_SIZE_M(512)>;
		has-dpd;
		t-enter-dpd = <3000>;
		t-exit-dpd = <30000>;
	};
};

/* ---- DMA1 — UART async transfers for digital O2 cells ---- */
&dma1 {
	status = "okay";
};

/* ---- TIM7 — solenoid deadman timer ----
 * One-shot hardware counter. When the alarm fires (ISR),
 * all solenoid GPIOs are forced low regardless of app state.
 */
&timers7 {
	st,prescaler = <11>;
	status = "okay";

	sol_timer: counter {
		status = "okay";
	};
};

/* ---- Internal ADC — voltage monitoring ----
 * PA0 = IN5 (VBUS_V), PC2 = IN3 (CAN_V), PC3 = IN4 (BATT_V)
 * Plus internal VREFINT and VBAT channels.
 */
&adc1 {
	pinctrl-0 = <&adc1_in5_pa0 &adc1_in3_pc2 &adc1_in4_pc3>;
	pinctrl-names = "default";
	st,adc-clock-source = "SYNC";
	st,adc-prescaler = <4>;
	status = "okay";
};

/* ---- VBAT sensor — VCC monitoring via STM32 internal 1/3 divider ----
 * On Jr, VBUS and VCC share a regulator so this also reflects VBUS voltage.
 */
&vbat {
	status = "okay";
};

/* ---- RNG — needed for stack canaries seed ----
 * Clocked from PLL Q (24MHz) via the CLK48 mux, matching the Rev2 config. */
&rng {
	clocks = <&rcc STM32_SRC_PLL_Q CLK48_SEL(2)>;
	status = "okay";
};

/* ---- Watchdog ----
 * Disabled until the watchdog feeding task is ported.
 * Enabling without a feeder causes an immediate WDT reset. */
&iwdg {
	status = "disabled";
};

/* ---- Flash partitions ----
 * Internal 256KB: bootloader + primary slot + NVS config
 * External 16MB:  secondary OTA slot + scratch + data
 */
&flash0 {
	partitions {
		compatible = "fixed-partitions";
		#address-cells = <1>;
		#size-cells = <1>;

		boot_partition: partition@0 {
			reg = <0x00000000 DT_SIZE_K(48)>;
			read-only;
		};
		slot0_partition: partition@c000 {
			reg = <0x0000c000 DT_SIZE_K(192)>;
		};
		storage_partition: partition@3c000 {
			reg = <0x0003c000 DT_SIZE_K(16)>;
		};
	};
};

&spi_flash {
	partitions {
		compatible = "fixed-partitions";
		#address-cells = <1>;
		#size-cells = <1>;

		slot1_partition: partition@0 {
			reg = <0x00000000 DT_SIZE_K(192)>;
		};
		scratch_partition: partition@30000 {
			reg = <0x00030000 DT_SIZE_K(64)>;
		};
	};
};
